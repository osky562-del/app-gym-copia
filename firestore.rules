rules_version = '2';

// ══════════════════════════════════════════════════
// KO95FIT — Firestore Security Rules v2
// Máxima protección del plan Pro + datos de usuario
// ══════════════════════════════════════════════════
//
// CÓMO DESPLEGAR:
//   1. Ve a Firebase Console → tu proyecto → Firestore → Rules
//   2. Copia y pega estas reglas
//   3. Pulsa "Publish"
//
// ESTRUCTURA:
//   /users/{uid}                    → Perfil (dueño lee/escribe con restricciones)
//   /users/{uid}/subscription/plan  → Plan Pro (SOLO admin / Cloud Functions)
//   /users/{uid}/workouts/{id}      → Entrenos (dueño, con validación)
//   /usernames/{name}               → Registro de nombres únicos
// ══════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: ¿Autenticado? ──
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: ¿Es el dueño del documento? ──
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Helper: ¿Es admin? (lista blanca de emails) ──
    function isAdmin() {
      return isAuth()
        && request.auth.token.email in [
          'osky_95@hotmail.com'
        ];
    }

    // ── Helper: ¿El usuario está intentando cambiar campos prohibidos? ──
    function isNotTouchingProtected() {
      let protected = ['subscription', 'pro_plan', 'plan', 'isAdmin', 'role', 'tier'];
      // Si el documento es nuevo, ninguno de estos campos puede estar presente
      // Si es una actualización, no pueden haber cambiado respecto al original
      return (request.method == 'create' ? !request.resource.data.keys().hasAny(protected) : true)
          && (request.method == 'update' ? !request.resource.data.diff(resource.data).affectedKeys().hasAny(protected) : true);
    }

    // ── Helper: Plan válido (para subscription) ──
    function isValidPlan(data) {
      return data.plan in ['free', 'pro', 'pro_plus']
        && data.keys().hasAll(['plan', 'updatedAt']);
    }

    // ── Helper: Tamaño de datos razonable ──
    function reasonableSize() {
      return request.resource.size < 500000; // 500KB max por documento
    }

    // ══════════════════════════════════════════════
    // USERS
    // ══════════════════════════════════════════════
    match /users/{userId} {

      // Lectura: solo el dueño o admin
      allow read: if isOwner(userId) || isAdmin();

      // Escritura: dueño (sin tocar campos protegidos) o admin
      allow create: if isOwner(userId) && isNotTouchingProtected() && reasonableSize();
      allow update: if (isOwner(userId) && isNotTouchingProtected() && reasonableSize())
                    || isAdmin();
      allow delete: if isAdmin(); // Solo admin puede borrar cuentas

      // ── SUBSCRIPTION (blindado) ──────────────────
      // Fuente de VERDAD del plan Pro.
      // NADIE puede escribir excepto:
      //   - Admin (con email verificado)
      //   - Cloud Functions (Admin SDK bypasea estas reglas)
      //   - Stripe webhooks via Cloud Functions
      match /subscription/{docId} {
        allow read: if isOwner(userId);

        // Validación estricta: solo plan válido + timestamp del servidor
        allow create: if isAdmin() && isValidPlan(request.resource.data);
        allow update: if isAdmin() && isValidPlan(request.resource.data);
        allow delete: if false; // Ni siquiera admin borra, se pone en 'free'
      }

      // ── WORKOUTS (validados) ─────────────────────
      match /workouts/{workoutId} {
        allow read: if isOwner(userId);

        // Escritura con validación de estructura
        allow create: if isOwner(userId)
          && reasonableSize()
          && request.resource.data.keys().hasAny(['date', 'exercises'])
          && request.resource.data.date is string;

        allow update: if isOwner(userId)
          && reasonableSize()
          && request.resource.data.date is string;

        allow delete: if isOwner(userId);
      }
    }

    // ══════════════════════════════════════════════
    // USERNAMES (registro único)
    // ══════════════════════════════════════════════
    match /usernames/{name} {
      // Cualquiera autenticado puede leer (para comprobar disponibilidad)
      allow read: if isAuth();

      // Crear: solo si el uid coincide y tiene los campos requeridos
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['uid', 'name'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 30
        && request.resource.data.keys().size() == 2; // Solo uid + name, nada más

      // No se puede modificar ni borrar (nombres permanentes)
      allow update: if false;
      allow delete: if false;
    }

    // ══════════════════════════════════════════════
    // DEFAULT: DENEGAR TODO lo no definido arriba
    // ══════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
